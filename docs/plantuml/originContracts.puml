@startuml

!$originColor = DeepSkyBlue
' !$originColor = WhiteSmoke
!$newColor = LightGreen
!$changedColor = Orange
!$thirdPartyColor = WhiteSmoke

' legend
' blue - Origin
' ' green - new
' ' orange - changed
' white - 3rd Party
' end legend

title "Origin Ether (OETH)\nAutomated Redemption Manager (ARM)\nContract Dependencies"


object "ZapperARM" as zap <<Origin>> #$originColor {
}

object "OriginARM" as arm <<Origin>><<Proxy>> #$originColor {
    shares: ARM-oETH-WETH
    assets: oETH, WETH
}

object "OETHVault" as oethVault <<Origin>><<Proxy>> #$thirdPartyColor {
    assets: oETH, WETH
}

object "Morpho Market" as morphoMarket <<Origin>><<Proxy>> #$originColor {
    asset: WETH
}

object "Yearn WETH ARM Vault" as morpho <<Morpho>> #$thirdPartyColor {
    asset: WETH
}

zap ..> arm
arm ..> oethVault
arm ..> morphoMarket
morphoMarket ..> morpho

@enduml